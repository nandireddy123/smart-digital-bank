# Copy this file to `.env` in the backend/ folder and fill in your values.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=smart_banking

JWT_SECRET_KEY=replace-with-a-long-random-string

# Leave SMTP_USERNAME / SMTP_PASSWORD blank to run in local dev mode --
# OTP codes will be printed to the console/log instead of emailed.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@smartbank.local
